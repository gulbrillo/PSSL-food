# ============================================================
#  PSSL LunchPad configuration
#  Easiest way to create this file: run  ./install.sh
# ============================================================

# Host port the web app is published on (http://server:WEB_PORT)
WEB_PORT=8080

# Public URL members use to reach the app (what login redirects and the
# Discord bot link to). Behind your own reverse proxy this is its public URL;
# with the bundled Caddy it is https://<DOMAIN>.
APP_URL=http://localhost:8080

# --- secrets (install.sh generates these) -------------------
POSTGRES_PASSWORD=change-me-long-random
SESSION_PASSWORD=change-me-at-least-32-characters-long!!
BOT_API_TOKEN=change-me-long-random

# --- WordPress SSO (Settings -> PSSL SSO on pssl.mae.ufl.edu) ---
WP_BASE_URL=https://pssl.mae.ufl.edu
WP_CLIENT_ID=paste-from-plugin-settings
WP_CLIENT_SECRET=paste-from-plugin-settings

# Emails that always get admin rights (comma separated).
# WordPress administrators/editors of the PSSL site are admins automatically.
ADMIN_EMAILS=

# --- Discord (optional — one app at https://discord.com/developers/applications) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
CHANNEL_REMINDER_HOURS=48
DM_REMINDER_HOURS=24

# --- optional bundled HTTPS proxy ---------------------------
# Uncomment both lines to serve the app yourself on ports 80/443 with
# automatic TLS (requires DNS pointing at this server):
#COMPOSE_PROFILES=caddy
#DOMAIN=food.pssl.mae.ufl.edu
