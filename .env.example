# ---- Copy to .env and fill in ----

# Public hostname of the food site (DNS must point at this server; Caddy gets TLS automatically)
DOMAIN=food.pssl.mae.ufl.edu

# Postgres password (internal only, pick anything long and random)
POSTGRES_PASSWORD=change-me-long-random

# Session cookie encryption key — MUST be at least 32 characters
SESSION_PASSWORD=change-me-at-least-32-characters-long!!

# ---- WordPress SSO (from the PSSL SSO Provider plugin settings page) ----
WP_BASE_URL=https://pssl.mae.ufl.edu
WP_CLIENT_ID=paste-from-plugin-settings
WP_CLIENT_SECRET=paste-from-plugin-settings

# Emails that always get admin rights in the food app (comma separated).
# WordPress administrators/editors of the PSSL site are admins automatically.
ADMIN_EMAILS=simon.barke@gmail.com

# ---- Discord (one application at https://discord.com/developers/applications) ----
# OAuth2 tab -> client id/secret, add redirect: https://<DOMAIN>/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Bot tab -> token
DISCORD_BOT_TOKEN=
# Your server id and the channel where reminders get posted (enable Developer Mode in Discord, right click -> Copy ID)
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

# Shared secret between bot and web API (pick anything long and random)
BOT_API_TOKEN=change-me-long-random

# Reminder schedule: hours before the RSVP deadline
CHANNEL_REMINDER_HOURS=48
DM_REMINDER_HOURS=24
