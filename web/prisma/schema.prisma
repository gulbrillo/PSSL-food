generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(cuid())
  wpId            Int                 @unique
  email           String              @unique
  name            String
  username        String?
  isAdmin         Boolean             @default(false)
  discordId       String?             @unique
  discordUsername String?
  createdAt       DateTime            @default(now())
  restrictions    UserRestriction[]
  rsvps           Rsvp[]
  votes           CatererVote[]
  requests        MealRequest[]
  catererPrefs    CatererPreference[]
}

model Restriction {
  id          String            @id @default(cuid())
  name        String            @unique
  description String? // what's excluded + common traps; shown as tooltip and in the admin overview
  users       UserRestriction[]
}

model UserRestriction {
  userId        String
  restrictionId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  restriction   Restriction @relation(fields: [restrictionId], references: [id], onDelete: Cascade)

  @@id([userId, restrictionId])
}

model Caterer {
  id       String              @id @default(cuid())
  name     String              @unique
  cuisine  String?
  url      String?
  notes    String?
  active   Boolean             @default(true)
  meetings Meeting[]
  votes    CatererVote[]
  prefs    CatererPreference[]
}

model CatererVote {
  userId    String
  catererId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  caterer   Caterer @relation(fields: [catererId], references: [id], onDelete: Cascade)

  @@id([userId, catererId])
}

/// A user's standing request for a specific caterer ("my usual"),
/// used to prefill the per-meeting request box.
model CatererPreference {
  userId    String
  catererId String
  text      String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  caterer   Caterer @relation(fields: [catererId], references: [id], onDelete: Cascade)

  @@id([userId, catererId])
}

model Meeting {
  id           String        @id @default(cuid())
  title        String        @default("PSSL Group Meeting")
  date         DateTime
  rsvpDeadline DateTime
  status       String        @default("scheduled") // scheduled | cancelled
  menuNotes    String?
  catererId    String?
  caterer      Caterer?      @relation(fields: [catererId], references: [id])
  rsvps        Rsvp[]
  requests     MealRequest[]
  guests       Guest[]
  reminders    ReminderLog[]
}

model Rsvp {
  userId    String
  meetingId String
  attending Boolean
  late      Boolean  @default(false) // last change happened after the RSVP deadline
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@id([userId, meetingId])
}

model MealRequest {
  userId    String
  meetingId String
  text      String
  late      Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@id([userId, meetingId])
}

/// Manually added attendee (visitor, collaborator, ...) for a single meeting.
model Guest {
  id           String   @id @default(cuid())
  meetingId    String
  name         String
  restrictions String[] // restriction names picked from the shared list
  addedByName  String?
  createdAt    DateTime @default(now())
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key   String @id
  value String
}

model ReminderLog {
  meetingId String
  kind      String // channel | dm
  sentAt    DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@id([meetingId, kind])
}
